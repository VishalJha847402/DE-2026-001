    "class counter():\n",
    "    def __init__(self):\n",
    "        self.count = 0\n",
    "\n",
    "    def increment(self):\n",
    "        self.count += 1\n",
    "        \n",
    "    def value(self):\n",
    "        return self.count\n",
    "\n",
    "\n",
    "c = counter()\n",
    "c.increment()\n",
    "c.value()\n",
    "\n",
    "\n"
   ]
